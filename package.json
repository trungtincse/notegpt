{
  "name": "notegpt",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter @notegpt/web dev",
    "dev:desktop": "pnpm --filter @notegpt/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.1"
  }
}
